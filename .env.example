# ─────────────────────────────────────────────────────────────────────────
# tab5-engine — Variables d'environnement
# Copier ce fichier en `.env` et renseigner les valeurs.
# NE JAMAIS committer le `.env` réel (il est dans .gitignore).
#
# Le moteur fonctionne avec UNE SEULE clé gratuite (GEMINI_API_KEY).
# Tout le reste est optionnel — les providers absents sont simplement
# désactivés et le moteur se dégrade gracieusement.
# ─────────────────────────────────────────────────────────────────────────

# ════════════════════════════════════════════════════════════
# SECTION 1 — SÉCURITÉ (REQUIS)
# ════════════════════════════════════════════════════════════

# Clé Bearer pour authentifier les appels à l'API locale du moteur.
# Toutes les routes /api/* sont protégées par cette clé.
# Générer une valeur forte : python -c "import secrets; print(secrets.token_urlsafe(32))"
MOTEUR_API_KEY=changez-moi

# Origines CORS autorisées (séparées par des virgules).
# Laisser vide pour autoriser toutes les origines (mode développement uniquement).
# Ex. : http://localhost:8000,http://192.168.1.100:8000
MOTEUR_CORS_ORIGINS=

# ════════════════════════════════════════════════════════════
# SECTION 2 — PROVIDERS LLM
# (Chaque clé active le provider dans la cascade de routage)
# ════════════════════════════════════════════════════════════

# ── Google Gemini (RECOMMANDÉ POUR DÉMARRER — GRATUIT) ──
# Obtenir une clé gratuite sur : https://aistudio.google.com/apikey
# Jusqu'à 5 clés pour la rotation automatique (contournement des quotas).
# Sert aussi aux embeddings RAG (gemini-embedding-004).
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=

# Modèle Gemini par défaut (optionnel, ex: gemini-2.5-flash, gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# ── Google Gemini Payant (GCP/Vertex — optionnel) ──
# Débloque Search Grounding et quotas plus élevés.
GEMINI_PAYANT_API_KEY=
GEMINI_PROJECT_NAME=

# ── GitHub Models (GRATUIT avec un compte GitHub) ──
# Accès à GPT-4o, Llama 3.3 70B, etc. via : https://github.com/marketplace/models
GITHUB_TOKEN=

# ── DeepSeek (très bon rapport qualité/prix) ──
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# ── Anthropic Claude ──
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Autres providers (tous optionnels) ──
MISTRAL_API_KEY=
COHERE_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
MINIMAX_API_KEY=
DEEPINFRA_API_KEY=
ZHIPU_API_KEY=

# ════════════════════════════════════════════════════════════
# SECTION 3 — HOME ASSISTANT (optionnel)
# ════════════════════════════════════════════════════════════

# URL de votre instance Home Assistant
HASS_URL=http://192.168.1.x:8123

# Token longue durée HA
# Profil HA → Sécurité → Jetons d'accès longue durée
HASS_TOKEN=

# Vérification TLS (true par défaut, mettre false si certificat auto-signé)
HA_VERIFY_TLS=true
# Chemin vers le certificat CA si HTTPS auto-signé (préféré à HA_VERIFY_TLS=false)
# HA_CA_BUNDLE=/chemin/vers/ha_ca.pem

# ════════════════════════════════════════════════════════════
# SECTION 4 — FONCTIONNALITÉS AVANCÉES (optionnel)
# ════════════════════════════════════════════════════════════

# ── Plugins et Tool-Maker (DÉSACTIVÉS par défaut — sécurité) ──
# Les plugins exécutent du code Python — n'activer que si les sources sont de confiance.
MOTEUR_ENABLE_PLUGINS=0
# Le ToolMakerAgent génère des outils Python automatiquement.
# Activer à 1 pour autoriser la persistance du code généré dans plugins/auto_generated/
MOTEUR_ENABLE_TOOL_MAKER=0

# ── WhatsApp (Meta Cloud API ou Twilio — optionnel) ──
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_USER_PHONE_NUMBER=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Observabilité Langfuse (optionnel) ──
# https://langfuse.com/ — tracing des appels LLM
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Divers ──
# Taux de conversion EUR→USD pour l'affichage des coûts (ex: 1.08)
EUR_USD_RATE=1.08
