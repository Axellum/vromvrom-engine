# Dockerfile.webhook
FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Configuration Serverless Agnostique : Cloud Run injecte PORT, local utilise 8080 par défaut
ENV PORT=8080
EXPOSE 8080

# Lancement du Moteur Multi-Agents (FastAPI)
CMD ["sh", "-c", "uvicorn main:app --host 0.0.0.0 --port ${PORT:-8080}"]
